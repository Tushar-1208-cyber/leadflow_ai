# LEADFLOW AI - ENVIRONMENT VARIABLES TEMPLATE

# Host Server Port
PORT=5000

# MongoDB Database Connection String
# For local testing, ensure a local MongoDB service is running (e.g. mongodb://127.0.0.1:27017/leadflow-ai)
# For production, supply your MongoDB Atlas connection URL
MONGO_URI=mongodb://127.0.0.1:27017/leadflow-ai

# JWT Encryption Keys
JWT_SECRET=leadflow_secret_key_12345
JWT_EXPIRE=30d

# Cross-Origin Frontend Routing URL
CLIENT_URL=http://localhost:5173

# Node Server Mode (development / production)
NODE_ENV=development
